-- Tween function for smooth movement
local function tweenToPosition(target, character)
    local tweenService = game:GetService("TweenService")
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    local distance = (hrp.Position - target.Position).Magnitude
    if distance < 5 then return end
    
    local tweenInfo = TweenInfo.new(
        math.min(distance / 50, 2),
        Enum.EasingStyle.Linear,
        Enum.EasingDirection.Out,
        0,
        false,
        0
    )
    
    local goal = {CFrame = target}
    local tween = tweenService:Create(hrp, tweenInfo, goal)
    tween:Play()
    tween.Completed:Wait()
end

local function applyBoatSpeed(speed)
    currentBoatSpeed = speed
    local Boats = workspace:FindFirstChild("Boats")
    if Boats then
        for _, boat in pairs(Boats:GetChildren()) do
            local vehicleSeat = boat:FindFirstChild("VehicleSeat")
            if vehicleSeat and vehicleSeat:IsA("VehicleSeat") then
                vehicleSeat.MaxSpeed = speed
            end
        end
    end
end

-- Auto No Clip function
local function applyNoClipToBoats(enable)
    local Boats = workspace:FindFirstChild("Boats")
    if Boats then
        for _, boat in pairs(Boats:GetChildren()) do
            for _, part in pairs(boat:GetDescendants()) do
                if part:IsA("BasePart") then
                    part.CanCollide = not enable
                end
            end
            local vehicleSeat = boat:FindFirstChild("VehicleSeat")
            if vehicleSeat and vehicleSeat:IsA("VehicleSeat") then
                vehicleSeat.CanCollide = not enable
            end
        end
    end
end

-- 🚢 FIXED Auto Sail Function - Direct Throttle Control
local function startAutoSail()
    if autoSailEnabled then return end
    autoSailEnabled = true
    
    local player = game:GetService("Players").LocalPlayer
    local playerName = player.Name
    
    autoSailThread = task.spawn(function()
        while autoSailEnabled do
            pcall(function()
                local Boats = workspace:FindFirstChild("Boats")
                if not Boats then return end
                
                local targetBoat = nil
                local boatCount = 0
                
                -- Count boats
                for _ in pairs(Boats:GetChildren()) do
                    boatCount = boatCount + 1
                end
                
                -- Find the right boat
                if boatCount == 1 then
                    for _, boat in pairs(Boats:GetChildren()) do
                        targetBoat = boat
                        break
                    end
                else
                    for _, boat in pairs(Boats:GetChildren()) do
                        local ownerValue = boat:FindFirstChild("Owner")
                        if ownerValue and ownerValue.Value == playerName then
                            targetBoat = boat
                            break
                        end
                        if string.find(boat.Name, playerName) then
                            targetBoat = boat
                            break
                        end
                    end
                end
                
                -- Direct boat control
                if targetBoat then
                    local vehicleSeat = targetBoat:FindFirstChild("VehicleSeat")
                    if vehicleSeat and vehicleSeat:IsA("VehicleSeat") then
                        -- ✅ Make boat go forward automatically
                        vehicleSeat.Throttle = 1  -- 1 = forward
                        vehicleSeat.ThrottleFloat = 1
                        
                        -- Make sure player is sitting in the boat
                        if not vehicleSeat.Occupant then
                            local character = player.Character
                            if character then
                                local humanoid = character:FindFirstChildOfClass("Humanoid")
                                if humanoid then
                                    -- Teleport to boat if far away
                                    local hrp = character:FindFirstChild("HumanoidRootPart")
                                    if hrp then
                                        local distance = (hrp.Position - vehicleSeat.Position).Magnitude
                                        if distance > 10 then
                                            tweenToPosition(vehicleSeat.CFrame * CFrame.new(0, 3, 0), character)
                                        else
                                            -- Sit in the seat
                                            vehicleSeat:Sit(humanoid)
                                        end
                                    end
                                end
                            end
                        end
                    end
                end
            end)
            task.wait(0.1)
        end
    end)
    
    Rayfield:Notify({
        Title = "🚢 Auto Sail ON",
        Content = "Boat moving forward automatically",
        Duration = 3
    })
end

local function stopAutoSail()
    autoSailEnabled = false
    if autoSailThread then
        task.cancel(autoSailThread)
        autoSailThread = nil
    end
    
    -- Stop the boat
    pcall(function()
        local Boats = workspace:FindFirstChild("Boats")
        if Boats then
            for _, boat in pairs(Boats:GetChildren()) do
                local vehicleSeat = boat:FindFirstChild("VehicleSeat")
                if vehicleSeat and vehicleSeat:IsA("VehicleSeat") then
                    vehicleSeat.Throttle = 0
                    vehicleSeat.ThrottleFloat = 0
                end
            end
        end
    end)
    
    Rayfield:Notify({
        Title = "🚢 Auto Sail OFF",
        Content = "Boat stopped",
        Duration = 3
    })
end

-- Monitor for new boats
task.spawn(function()
    while task.wait(1) do
        if currentBoatSpeed > 0 then
            applyBoatSpeed(currentBoatSpeed)
        end
        if autoNoClipEnabled then
            applyNoClipToBoats(true)
        end
    end
end)

local Boats = workspace:FindFirstChild("Boats")
if Boats then
    Boats.ChildAdded:Connect(function(newBoat)
        task.wait(0.5)
        if currentBoatSpeed > 0 then
            local vehicleSeat = newBoat:FindFirstChild("VehicleSeat")
            if vehicleSeat and vehicleSeat:IsA("VehicleSeat") then
                vehicleSeat.MaxSpeed = currentBoatSpeed
            end
        end
        if autoNoClipEnabled then
            for _, part in pairs(newBoat:GetDescendants()) do
                if part:IsA("BasePart") then
                    part.CanCollide = false
                end
            end
            local vehicleSeat = newBoat:FindFirstChild("VehicleSeat")
            if vehicleSeat and vehicleSeat:IsA("VehicleSeat") then
                vehicleSeat.CanCollide = false
            end
        end
    end)
end

